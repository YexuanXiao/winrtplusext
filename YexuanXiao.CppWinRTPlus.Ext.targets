<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Target Name="CppWinRTPlusExtAddModuleInterfaces"
          BeforeTargets="FixupCLCompileOptions">
    <ItemGroup>
      <ClCompile Include="$(CppWinRTPlusExtSourceDir)*.ixx">
        <CompileAs>CompileAsCppModule</CompileAs>
        <ModulesSupported>true</ModulesSupported>
        <PrecompiledHeader>NotUsing</PrecompiledHeader>
      </ClCompile>
    </ItemGroup>
  </Target>

</Project>
